# Python bytecode / caches
__pycache__/
*.py[cod]
*.pyd

# Virtual environments
.venv/
venv/
env/
.env/

# Local env files (secrets — never commit)
.env
.env.*
!.env.example

# Test / coverage artifacts
.pytest_cache/
.coverage
.coverage.*
coverage.xml
htmlcov/
.tox/
.nox/

# Type checker / linter caches
.mypy_cache/
.ruff_cache/
.pytype/

# Build artifacts
build/
dist/
*.egg-info/

# Local test reports (generated by Dockerfile.test / CI runs)
reports/

# Terraform local state / secrets / scratch (never commit)
**/.terraform/
**/*.tfstate
**/*.tfstate.*
**/crash.log
crash.*.log
*.tfplan
tfplan
terraform.tfvars
terraform.tfvars.json
*.auto.tfvars
*.auto.tfvars.json
!*.tfvars.example
!terraform.tfvars.example

# Secrets / keys (defense-in-depth)
*.pem
*.key
*.p12
*.pfx

# Editor / OS
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp
*~
