# Python bytecode / caches
__pycache__/
*.py[cod]
*.pyd

# Virtual environments
.venv/
venv/
env/
.env/

# Test / coverage artifacts
.pytest_cache/
.coverage
.coverage.*
coverage.xml
htmlcov/
.tox/
.nox/

# Type checker / linter caches
.mypy_cache/
.ruff_cache/
.pytype/

# Build artifacts
build/
dist/
*.egg-info/

# Local test reports (generated by Dockerfile.test / CI runs)
reports/

# Terraform state kept locally by default
terraform/terraform.tfstate
terraform/terraform.tfstate.backup

# Terraform local state (never commit)
**/.terraform/
**/*.tfstate
**/*.tfstate.*
**/crash.log

# Secrets / keys (defense-in-depth)
*.pem
*.key
*.p12
*.pfx
~/.ssh/mqtt-ci-key.pem

# Editor / OS
.DS_Store
.idea/
.vscode/
